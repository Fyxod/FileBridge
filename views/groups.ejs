<%- include("partials/header", { title: "Groups" }) %>
<section class="hero hero-compact">
  <div>
    <p class="eyebrow">Teams and permissions</p>
    <h1>Share with the right people, fast.</h1>
    <p class="lede">Create groups, manage members, and tune who can upload, edit, or share from one clean workspace.</p>
  </div>
  <div class="hero-panel">
    <span class="metric-label">Active groups</span>
    <strong><%= groups.length %></strong>
    <span>available to your account</span>
  </div>
</section>

<section class="card card-feature">
  <div class="card-heading">
    <p class="eyebrow">New workspace</p>
    <h2>Create group</h2>
  </div>
  <form method="post" action="/groups" class="form">
    <label>Name</label>
    <input name="name" required data-suggest="groups">

    <label>Member user IDs</label>
    <input name="memberUserIds" placeholder="user1,user2" data-suggest="users" data-suggest-multi="true">

    <fieldset class="fieldset permission-grid">
      <legend>Permissions</legend>
      <label><input type="checkbox" name="canUpload" checked> Upload</label>
      <label><input type="checkbox" name="canEdit" checked> Edit</label>
      <label><input type="checkbox" name="canShare" checked> Share</label>
    </fieldset>

    <button type="submit">Create group</button>
  </form>
</section>

<section class="card">
  <div class="section-title">
    <div>
      <p class="eyebrow">Directory</p>
      <h2>Your groups</h2>
    </div>
    <span class="pill"><%= groups.length %> total</span>
  </div>
  <% if (!groups.length) { %>
    <div class="empty-state">
      <h3>No groups yet</h3>
      <p>Create your first group above to simplify file access for a team.</p>
    </div>
  <% } else { %>
    <div class="group-grid">
    <% groups.forEach((group) => { %>
      <div class="group">
        <div class="group-header">
          <div>
            <p class="eyebrow">Group</p>
            <h3><%= group.name %></h3>
          </div>
          <span class="pill"><%= group.members.length %> members</span>
        </div>
        <p class="muted">Members: <%= group.members.map((m) => m.userId).join(", ") %></p>

        <div class="group-actions">
        <form method="post" action="/groups/<%= group._id %>/members" class="inline action-form">
          <input name="memberUserId" placeholder="userId" data-suggest="users">
          <button type="submit">Add member</button>
        </form>

        <form method="post" action="/groups/<%= group._id %>/members/remove" class="inline action-form">
          <input name="memberUserId" placeholder="userId" data-suggest="users">
          <button class="button-secondary" type="submit">Remove member</button>
        </form>

        <form method="post" action="/groups/<%= group._id %>/permissions" class="inline action-form permissions-form">
          <label><input type="checkbox" name="canUpload" <%= group.permissions.canUpload ? "checked" : "" %>> Upload</label>
          <label><input type="checkbox" name="canEdit" <%= group.permissions.canEdit ? "checked" : "" %>> Edit</label>
          <label><input type="checkbox" name="canShare" <%= group.permissions.canShare ? "checked" : "" %>> Share</label>
          <button type="submit">Update permissions</button>
        </form>
        </div>
      </div>
    <% }) %>
    </div>
  <% } %>
</section>
<%- include("partials/footer") %>
