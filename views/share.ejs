<%- include("partials/header", { title: "Shared File" }) %>
<section class="hero hero-compact">
  <div>
    <p class="eyebrow">Shared file</p>
    <h1>Your download is ready.</h1>
    <p class="lede">This file was shared through a FileBridge secure link.</p>
  </div>
</section>

<section class="card shared-card">
  <div class="file-cell file-cell-large">
    <span class="file-icon"><%= (file.name || "?").charAt(0).toUpperCase() %></span>
    <div>
      <h2><%= file.name %></h2>
      <p class="muted"><%= file.mimeType %> · <%- include('_filesize', { size: file.size }) %></p>
    </div>
  </div>
  <form method="post" action="/files/share/<%= file.access.shareToken %>/download">
    <button type="submit">Download</button>
  </form>
</section>
<%- include("partials/footer") %>
