<%- include("partials/header", { title: "Dashboard" }) %>
<section class="hero hero-dashboard">
  <div>
    <p class="eyebrow">Personal vault</p>
    <h1>Store, find, and share files without the clutter.</h1>
    <p class="lede">A cleaner command center for uploads, access control, links, favorites, and storage insights.</p>
  </div>
  <div class="hero-panel">
    <span class="metric-label">Total storage</span>
    <strong><%- include('_filesize', { size: storage.totalSize }) %></strong>
    <span><%= storage.count %> files protected in FileBridge</span>
  </div>
</section>

<% if (error) { %>
  <p class="alert alert-error">Error: <%= error %></p>
<% } %>

<section class="grid">
  <div class="card card-feature">
    <div class="card-heading">
      <p class="eyebrow">Add something new</p>
      <h2>Upload</h2>
    </div>
    <form method="post" action="/files/upload" enctype="multipart/form-data" class="form">
      <label>File</label>
      <input type="file" name="file" required>

      <label>Display name</label>
      <input name="name" placeholder="Optional name" data-suggest="fileNames">

      <label>Tags</label>
      <input name="tags" placeholder="tag1,tag2" data-suggest="tags" data-suggest-multi="true">

      <label>Folder</label>
      <input name="folderPath" placeholder="/projects" data-suggest="folders">

      <label>Visibility</label>
      <select name="visibility">
        <option value="private">Private</option>
        <option value="public">Public</option>
        <option value="users">Specific users</option>
        <option value="groups">Specific groups</option>
        <option value="link">Share link</option>
      </select>

      <label>Allowed user IDs</label>
      <input name="allowedUserIds" placeholder="user1,user2" data-suggest="users" data-suggest-multi="true">

      <label>Allowed group names</label>
      <input name="allowedGroupNames" placeholder="team-alpha,team-beta" data-suggest="groups" data-suggest-multi="true">

      <button type="submit">Upload</button>
    </form>
  </div>

  <div class="card">
    <div class="card-heading">
      <p class="eyebrow">Refine the list</p>
      <h2>Search</h2>
    </div>
    <form method="get" action="/files" class="form">
      <label>Query</label>
      <input name="q" value="<%= filters.q || "" %>" data-suggest="searchTerms">

      <label>Tag</label>
      <input name="tag" value="<%= filters.tag || "" %>" data-suggest="tags">

      <label>Type</label>
      <input name="type" value="<%= filters.type || "" %>" data-suggest="mimeTypes">

      <label>From</label>
      <input type="date" name="from" value="<%= filters.from || "" %>">

      <label>To</label>
      <input type="date" name="to" value="<%= filters.to || "" %>">

      <label>Sort</label>
      <select name="sort">
        <option value="createdAt">Date</option>
        <option value="name" <%= filters.sort === "name" ? "selected" : "" %>>Name</option>
        <option value="size" <%= filters.sort === "size" ? "selected" : "" %>>Size</option>
      </select>

      <label>Order</label>
      <select name="order">
        <option value="desc">Desc</option>
        <option value="asc" <%= filters.order === "asc" ? "selected" : "" %>>Asc</option>
      </select>

      <button type="submit">Apply</button>
    </form>
  </div>

  <div class="card">
    <div class="card-heading">
      <p class="eyebrow">Usage snapshot</p>
      <h2>Storage</h2>
    </div>
    <div class="stats">
      <div>
        <span>Total files</span>
        <strong><%= storage.count %></strong>
      </div>
      <div>
        <span>Total size</span>
        <strong><%- include('_filesize', { size: storage.totalSize }) %></strong>
      </div>
    </div>
    <ul class="storage-list">
      <% storageByType.forEach((item) => { %>
        <li>
          <span><%= item._id %></span>
          <strong><%- include('_filesize', { size: item.totalSize }) %></strong>
        </li>
      <% }) %>
    </ul>
  </div>
</section>

<section class="card">
  <div class="section-title">
    <div>
      <p class="eyebrow">Library</p>
      <h2>Files</h2>
    </div>
    <span class="pill"><%= files.length %> visible</span>
  </div>
  <% if (!files.length) { %>
    <div class="empty-state">
      <h3>No files yet</h3>
      <p>Upload your first file above and it will appear here with sharing controls.</p>
    </div>
  <% } else { %>
    <div class="table-wrap">
    <table class="table">
      <thead>
        <tr>
          <th>Name</th>
          <th>Size</th>
          <th>Visibility</th>
          <th>Tags</th>
          <th>Actions</th>
        </tr>
      </thead>
      <tbody>
        <% files.forEach((file) => { %>
          <tr>
            <td>
              <div class="file-cell">
                <span class="file-icon"><%= (file.name || "?").charAt(0).toUpperCase() %></span>
                <div>
                  <strong><%= file.name %></strong><br>
                  <span class="muted"><%= file.originalName %> · <%= file.folderPath || "/" %></span>
                </div>
              </div>
              <% if (file.access && file.access.shareToken) { %>
                <div class="share-link">Share link: <a href="http://localhost:3000/files/share/<%= file.access.shareToken %>" target="_blank">localhost:3000/files/share/<%= file.access.shareToken %></a></div>
              <% } %>
            </td>
            <td><%- include('_filesize', { size: file.size }) %></td>
            <td><span class="badge badge-<%= file.access.visibility %>"><%= file.access.visibility %></span></td>
            <td>
              <div class="tag-list">
                <% if ((file.tags || []).length) { %>
                  <% file.tags.forEach((tag) => { %>
                    <span><%= tag %></span>
                  <% }) %>
                <% } else { %>
                  <span class="muted">No tags</span>
                <% } %>
              </div>
            </td>
            <td>
              <div class="actions">
                <form method="post" action="/files/<%= file._id %>/rename" class="inline action-form">
                  <input name="name" value="<%= file.name %>" data-suggest="fileNames">
                  <button type="submit">Rename</button>
                </form>

                <form method="post" action="/files/<%= file._id %>/move" class="inline action-form">
                  <input name="folderPath" value="<%= file.folderPath %>" data-suggest="folders">
                  <button type="submit">Move</button>
                </form>

                <form method="post" action="/files/<%= file._id %>/tags" class="inline action-form">
                  <input name="tags" value="<%= (file.tags || []).join(", ") %>" data-suggest="tags" data-suggest-multi="true">
                  <button type="submit">Tags</button>
                </form>

                <form method="post" action="/files/<%= file._id %>/access" class="inline action-form action-form-wide">
                  <select name="visibility">
                    <option value="private" <%= file.access.visibility === "private" ? "selected" : "" %>>Private</option>
                    <option value="public" <%= file.access.visibility === "public" ? "selected" : "" %>>Public</option>
                    <option value="users" <%= file.access.visibility === "users" ? "selected" : "" %>>Users</option>
                    <option value="groups" <%= file.access.visibility === "groups" ? "selected" : "" %>>Groups</option>
                    <option value="link" <%= file.access.visibility === "link" ? "selected" : "" %>>Link</option>
                  </select>
                  <input name="allowedUserIds" placeholder="user1,user2" data-suggest="users" data-suggest-multi="true">
                  <input name="allowedGroupNames" placeholder="team-alpha,team-beta" data-suggest="groups" data-suggest-multi="true">
                  <button type="submit">Share</button>
                </form>

                <form method="post" action="/files/<%= file._id %>/share-link" class="inline">
                  <button class="button-secondary" type="submit"><%= file.access.shareToken ? "Revoke link" : "Create link" %></button>
                </form>

                <form method="post" action="/files/<%= file._id %>/favorite" class="inline">
                  <button class="button-secondary" type="submit"><%= favorites.has(file._id.toString()) ? "Unfavorite" : "Favorite" %></button>
                </form>

                <a class="button" href="/files/<%= file._id %>/download">Download</a>
                <form method="post" action="/files/<%= file._id %>/delete" class="inline">
                  <button class="button-danger" type="submit">Delete</button>
                </form>
              </div>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
    </div>
  <% } %>
</section>
<%- include("partials/footer") %>
